@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam actorStyle awesome

actor Cliente
actor Administrador

rectangle "Sistema de Gestión de Reserva Hotelera\nHotel Pacific Reef" {

  usecase "Registrarse" as UC1
  usecase "Iniciar sesión" as UC2
  usecase "Consultar disponibilidad" as UC3
  usecase "Ver habitaciones" as UC4
  usecase "Ver detalle de habitación" as UC5
  usecase "Registrar reserva" as UC6
  usecase "Pagar abono" as UC7
  usecase "Recibir ticket QR" as UC8
  usecase "Modificar reserva" as UC9
  usecase "Cancelar reserva" as UC10

  usecase "Gestionar reservas" as UA2
  usecase "Gestionar clientes" as UA3
  usecase "Gestionar tarifas" as UA4
  usecase "Consultar reportes" as UA5
  usecase "Crear cuentas de trabajadores" as UA6
}

Cliente --> UC1
Cliente --> UC2
Cliente --> UC3
Cliente --> UC4
Cliente --> UC5
Cliente --> UC6
Cliente --> UC7
Cliente --> UC8
Cliente --> UC9
Cliente --> UC10

Administrador --> UC2
Administrador --> UA2
Administrador --> UA3
Administrador --> UA4
Administrador --> UA5
Administrador --> UA6

UC6 .> UC7 : <<include>>
UC7 .> UC8 : <<include>>
UC3 .> UC4 : <<include>>
UC4 .> UC5 : <<include>>

@enduml